rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: recebimentos
    // Document ID: auto-generated
    // Fields:
    //   - supplier: string
    //   - carrier: string
    //   - invoice: string
    //   - orderNumber: string
    //   - volumes: string
    //   - temperature: string
    //   - collaborator: string
    //   - date: string
    //   - time: string
    //   - observations: string
    //   - checklist: string
    //   - dataHoraRegistro: string
    //   - createdAt: number
    //   - uid: string
    //
    // Collection: quarentenas
    // Document ID: auto-generated
    // Fields:
    //   - supplier: string
    //   - carrier: string
    //   - invoice: string
    //   - orderNumber: string
    //   - volumes: string
    //   - collaborator: string
    //   - pharmacist: string
    //   - date: string
    //   - time: string
    //   - observations: string
    //   - finalDecision: string
    //   - recebimentoChecks: string
    //   - farmaciaChecks: string
    //   - dataHoraRegistro: string
    //   - createdAt: number
    //   - uid: string
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email in ['joaopsfarma@gmail.com', 'outro@email.com']);
    }

    function isValidRecebimento(data) {
      return data.keys().hasAll(['supplier', 'date', 'time', 'uid', 'createdAt']) &&
             data.supplier is string &&
             data.date is string &&
             data.time is string &&
             data.uid is string &&
             data.createdAt is number;
    }

    function isValidQuarentena(data) {
      return data.keys().hasAll(['supplier', 'date', 'time', 'uid', 'createdAt']) &&
             data.supplier is string &&
             data.date is string &&
             data.time is string &&
             data.uid is string &&
             data.createdAt is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /recebimentos/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidRecebimento(request.resource.data) && uidUnchanged();
      allow update: if (isOwner() || isAdmin()) && isValidRecebimento(request.resource.data) && uidNotModified();
      allow delete: if isOwner() || isAdmin();
    }

    match /quarentenas/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidQuarentena(request.resource.data) && uidUnchanged();
      allow update: if (isOwner() || isAdmin()) && isValidQuarentena(request.resource.data) && uidNotModified();
      allow delete: if isOwner() || isAdmin();
    }
  }
}
